<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bootstrap_background"
    android:fillViewport="true"
>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="20dp"
    >
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="8dp"
            android:background="@drawable/screen_panel_background"
            android:orientation="vertical"
        >
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:adjustViewBounds="true"
                android:contentDescription="@string/chapter_hero_desc"
                android:scaleType="centerCrop"
                android:src="@drawable/rainbowdash_chapter_hero"
            />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="@string/chapter_title"
                android:textColor="@color/bootstrap_primary_text"
                android:textSize="30sp"
                android:textStyle="bold"
            />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/chapter_subtitle"
                android:textColor="@color/bootstrap_secondary_text"
                android:textSize="15sp"
            />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:orientation="horizontal"
            >
                <Button
                    android:id="@+id/chapter_button_1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/chapter_button_primary"
                    android:minHeight="88dp"
                    android:text="@string/chapter_option_1"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"
                />

                <Button
                    android:id="@+id/chapter_button_2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/chapter_button_primary"
                    android:minHeight="88dp"
                    android:text="@string/chapter_option_2"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"
                />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="horizontal"
            >
                <Button
                    android:id="@+id/chapter_button_3"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/chapter_button_primary"
                    android:minHeight="88dp"
                    android:text="@string/chapter_option_3"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"
                />

                <Button
                    android:id="@+id/chapter_button_4"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/chapter_button_primary"
                    android:minHeight="88dp"
                    android:text="@string/chapter_option_4"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"
                />
            </LinearLayout>

            <Button
                android:id="@+id/chapter_button_end"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/chapter_button_final"
                android:minHeight="92dp"
                android:text="@string/chapter_option_end"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="20sp"
                android:textStyle="bold"
            />

            <TextView
                android:id="@+id/chapter_error"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:textColor="@android:color/holo_red_light"
                android:textSize="14sp"
                android:visibility="gone"
            />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
